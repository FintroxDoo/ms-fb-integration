# --- FreshBooks (OAuth2) ---
# Register an app at https://my.freshbooks.com/#/developer to get these.
# FreshBooks REQUIRES an HTTPS redirect URI. For local dev run the app over
# HTTPS (self-signed cert, see README) or use a tunnel (ngrok/cloudflared).
FRESHBOOKS_CLIENT_ID=
FRESHBOOKS_CLIENT_SECRET=
FRESHBOOKS_REDIRECT_URI=https://localhost:3000/auth/freshbooks/callback
FRESHBOOKS_API_BASE=https://api.freshbooks.com
FRESHBOOKS_AUTH_BASE=https://auth.freshbooks.com
FRESHBOOKS_SCOPES=user:profile:read user:invoices:read user:clients:read

# --- UpFlow (API key + secret) ---
# Generate in the UpFlow app under Settings (sandbox project).
# NOTE: base URL must include the /v1 path segment.
UPFLOW_API_KEY=
UPFLOW_API_SECRET=
UPFLOW_API_BASE=https://api.sandbox.upflow.io/v1

# --- App ---
PORT=3000
# Postgres. Local dev: docker-compose (below). Staging: managed Postgres with
# ?sslmode=require, e.g. postgresql://USER:PASS@HOST:25060/freshbooks_upflow?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/freshbooks_upflow?schema=public

# Local HTTPS (needed for the FreshBooks OAuth redirect). Generate self-signed
# certs into ./certs (see README), or set HTTPS_ENABLED=false if using a tunnel.
HTTPS_ENABLED=true
HTTPS_KEY_FILE=./certs/key.pem
HTTPS_CERT_FILE=./certs/cert.pem

# --- Sync ---
# Cron disabled by default; enable to poll FreshBooks on an interval.
SYNC_CRON_ENABLED=false
SYNC_CRON_EXPRESSION=*/15 * * * *
# Max concurrent UpFlow writes (UpFlow recommends <=5 on bulk import).
SYNC_CONCURRENCY=5

# --- Webhooks ---
# Public HTTPS URL FreshBooks posts events to (e.g. ngrok static domain).
# Required only for `npm run webhooks:register`. Callback uri becomes
# <PUBLIC_BASE_URL>/webhooks/freshbooks
PUBLIC_BASE_URL=
# Verify the X-FreshBooks-Hmac-SHA256 signature on incoming events (keep true).
WEBHOOK_VERIFY_SIGNATURE=true
