{
  "name": "ms-fb-integration",
  "version": "0.1.0",
  "description": "NestJS middleware syncing FreshBooks clients + invoices into UpFlow",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "backfill": "ts-node -r tsconfig-paths/register src/commands/backfill.ts",
    "webhooks:register": "ts-node -r tsconfig-paths/register src/commands/webhooks.ts register",
    "webhooks:list": "ts-node -r tsconfig-paths/register src/commands/webhooks.ts list",
    "webhooks:clear": "ts-node -r tsconfig-paths/register src/commands/webhooks.ts clear",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint \"{src,test}/**/*.ts\" --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "check": "npm run test && npm run lint && npm run typecheck",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "DATABASE_URL=\"$(node -r dotenv/config scripts/build-db-url.js)\" prisma migrate dev",
    "prisma:deploy": "DATABASE_URL=\"$(node -r dotenv/config scripts/build-db-url.js)\" prisma migrate deploy",
    "prisma:studio": "DATABASE_URL=\"$(node -r dotenv/config scripts/build-db-url.js)\" prisma studio"
  },
  "dependencies": {
    "@nestjs/axios": "^3.1.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/schedule": "^4.1.2",
    "@prisma/client": "^5.22.0",
    "axios": "^1.7.9",
    "p-limit": "^3.1.0",
    "prisma": "^5.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "prisma": "^5.22.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
